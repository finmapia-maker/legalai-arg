function logA(accion,campo,ant,nvo,ref,det){
  ALOG.unshift({id:'AUD-'+String(ALOG.length+1).padStart(3,'0'),fecha:new Date().toLocaleString('es-AR'),u:'owner',accion,campo,ant,nvo,ref,det});
