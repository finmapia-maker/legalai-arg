<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LegalAI ARG · Panel Owner</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;0,900;1,700;1,800&family=Lato:wght@300;400;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg:       #0a0a0a;
  --bg2:      #111111;
  --bg3:      #161616;
  --bg4:      #1c1c1c;
  --border:   #222222;
  --border2:  #2e2e2e;
  --gold:     #c9a84c;
  --gold2:    #a8872e;
  --gold-lt:  #e8c97a;
  --gold-dim: rgba(201,168,76,.1);
  --gold-glow:rgba(201,168,76,.05);
  --text:     #f0ece4;
  --text2:    #9a9082;
  --text3:    #524b40;
  --green:    #5a9a6e;
  --red2:     #b06060;
  --orange:   #b07840;
  --serif:    'Playfair Display', Georgia, serif;
  --sans:     'Lato', sans-serif;
  --mono:     'DM Mono', monospace;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:14px;background:var(--bg);color:var(--text);font-family:var(--sans)}
body{display:flex;min-height:100vh;overflow:hidden}

/* LOGIN */
#login-screen{
  display:flex;align-items:center;justify-content:center;
  height:100vh;width:100%;
  background:var(--bg);
  background-image:radial-gradient(ellipse 70% 50% at 50% -10%,rgba(201,168,76,.08),transparent 60%);
}
.login-box{
  width:360px;background:var(--bg2);border:1px solid var(--border2);
  padding:44px 40px;position:relative;
}
.login-box::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent,var(--gold),transparent);
}
.login-logo{font-family:var(--serif);font-size:22px;font-weight:900;color:var(--text);margin-bottom:5px}
.login-logo em{color:var(--gold);font-style:italic}
.login-sub{font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--text3);margin-bottom:30px}
.fg{margin-bottom:18px}
.fg label{display:block;font-size:9px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--text3);margin-bottom:7px}
.fg input{
  width:100%;background:var(--bg3);border:1px solid var(--border2);
  color:var(--text);font-family:var(--mono);font-size:13px;
  padding:10px 13px;outline:none;transition:.2s;
}
.fg input:focus{border-color:var(--gold);background:var(--bg4)}
.btn-gold{
  width:100%;padding:12px;background:var(--gold);color:#0a0a0a;
  font-family:var(--sans);font-size:11px;font-weight:700;
  letter-spacing:.12em;text-transform:uppercase;
  border:none;cursor:pointer;transition:.2s;
}
.btn-gold:hover{background:var(--gold-lt)}
.login-err{font-size:11px;color:var(--red2);margin-top:10px;display:none;font-family:var(--mono)}

/* APP */
#app{display:none;width:100%}

/* SIDEBAR */
#sidebar{
  width:228px;flex-shrink:0;background:var(--bg2);
  border-right:1px solid var(--border);
  display:flex;flex-direction:column;
  height:100vh;position:sticky;top:0;
}
.sl{
  padding:22px 20px 18px;
  border-bottom:1px solid var(--border);
}
.sl .brand{font-family:var(--serif);font-size:18px;font-weight:900;color:var(--text);line-height:1}
.sl .brand em{color:var(--gold);font-style:italic}
.sl .brand-sub{font-size:9px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--text3);margin-top:5px}
.snav{flex:1;padding:14px 0;overflow-y:auto}
.nsec{padding:10px 20px 4px;font-size:8.5px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--text3)}
.ni{
  display:flex;align-items:center;gap:11px;
  padding:9px 20px;cursor:pointer;
  font-size:12.5px;color:var(--text2);
  border-left:2px solid transparent;transition:.15s;
}
.ni:hover{color:var(--text);background:var(--bg3)}
.ni.active{color:var(--gold);background:var(--gold-glow);border-left-color:var(--gold);font-weight:700}
.ni .ic{width:15px;font-size:13px;opacity:.55;flex-shrink:0}
.ni.active .ic{opacity:1}
.sb{padding:14px 20px;border-top:1px solid var(--border)}
.sb-user{font-size:9px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--text3);margin-bottom:8px}
.btn-logout{
  width:100%;padding:7px;background:transparent;border:1px solid var(--border2);
  color:var(--text3);font-size:10px;font-weight:700;letter-spacing:.08em;
  text-transform:uppercase;cursor:pointer;transition:.15s;
}
.btn-logout:hover{border-color:var(--red2);color:var(--red2)}

/* MAIN */
#main{flex:1;display:flex;flex-direction:column;height:100vh;overflow:hidden}
#topbar{
  height:50px;background:var(--bg2);border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 24px;flex-shrink:0;
}
.tb-title{font-family:var(--serif);font-size:17px;font-weight:800;color:var(--text)}
.tb-r{display:flex;align-items:center;gap:14px}
.live{
  display:flex;align-items:center;gap:6px;
  font-size:9px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--green);
}
.live::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--green);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.tb-date{font-size:10px;color:var(--text3);font-family:var(--mono)}

/* CONTENT */
#content{flex:1;overflow-y:auto;background:var(--bg)}
.page{display:none;padding:24px}
.page.active{display:block}

/* PAGE HEADER */
.ph{
  display:flex;align-items:flex-start;justify-content:space-between;
  margin-bottom:22px;padding-bottom:18px;border-bottom:1px solid var(--border);
}
.ph-title{font-family:var(--serif);font-size:22px;font-weight:900;color:var(--text)}
.ph-title em{color:var(--gold);font-style:italic}
.ph-sub{font-size:11px;color:var(--text2);margin-top:4px}

/* CARDS */
.cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:10px;margin-bottom:20px}
.card{
  background:var(--bg2);border:1px solid var(--border);
  padding:18px 16px;position:relative;overflow:hidden;transition:.2s;
}
.card::after{
  content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--gold),transparent);
  opacity:0;transition:.2s;
}
.card:hover{border-color:var(--border2)}
.card:hover::after{opacity:.35}
.cl{font-size:9px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--text3);margin-bottom:9px}
.cv{font-family:var(--serif);font-size:24px;font-weight:900;color:var(--text);line-height:1}
.cv.gold{color:var(--gold)}
.cv.green{color:var(--green)}
.cv.red{color:var(--red2)}
.cv.dim{color:var(--text2)}
.cs{font-size:10px;color:var(--text3);margin-top:5px}

/* FILTER */
.fb{
  background:var(--bg2);border:1px solid var(--border);
  padding:13px 15px;margin-bottom:12px;
  display:flex;flex-wrap:wrap;gap:10px;align-items:flex-end;
}
.fg2{display:flex;flex-direction:column;gap:5px}
.fg2 label{font-size:8.5px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--text3)}
.fg2 input,.fg2 select{
  background:var(--bg3);border:1px solid var(--border2);
  color:var(--text);font-family:var(--mono);font-size:11px;
  padding:5px 9px;outline:none;min-width:112px;transition:.15s;
}
.fg2 input:focus,.fg2 select:focus{border-color:var(--gold)}
.fg2 select option{background:var(--bg3)}
.btn-f{
  padding:6px 14px;background:var(--gold);color:#0a0a0a;
  border:none;cursor:pointer;font-size:10px;font-weight:700;
  letter-spacing:.08em;text-transform:uppercase;transition:.15s;height:29px;
}
.btn-f:hover{background:var(--gold-lt)}
.btn-cl{
  padding:6px 12px;background:transparent;color:var(--text3);
  border:1px solid var(--border2);cursor:pointer;
  font-size:10px;font-weight:700;letter-spacing:.06em;
  text-transform:uppercase;transition:.15s;height:29px;
}
.btn-cl:hover{color:var(--text);border-color:var(--border)}

/* SEARCH */
.sb2{display:flex;gap:10px;margin-bottom:12px}
.sb2 input{
  flex:1;background:var(--bg2);border:1px solid var(--border2);
  color:var(--text);font-size:12px;padding:9px 14px;outline:none;transition:.15s;
}
.sb2 input:focus{border-color:var(--gold)}
.sb2 input::placeholder{color:var(--text3)}

/* TABLE */
.tw{background:var(--bg2);border:1px solid var(--border);overflow:auto;max-height:530px}
table{width:100%;border-collapse:collapse;font-size:12px}
thead{position:sticky;top:0;z-index:2}
th{
  background:var(--bg3);padding:9px 13px;text-align:left;
  font-size:8.5px;font-weight:700;text-transform:uppercase;letter-spacing:.12em;
  color:var(--text3);border-bottom:1px solid var(--border2);white-space:nowrap;cursor:pointer;
}
th:hover{color:var(--text2)}
td{padding:9px 13px;border-bottom:1px solid var(--border);color:var(--text2);white-space:nowrap;vertical-align:middle}
tr:hover td{background:var(--bg3);color:var(--text)}
tr:last-child td{border-bottom:none}

/* BADGES */
.badge{display:inline-block;padding:2px 8px;font-size:9px;font-weight:700;letter-spacing:.06em;text-transform:uppercase}
.b-confirmada{background:rgba(90,154,110,.12);color:#6aba88;border:1px solid rgba(90,154,110,.25)}
.b-pendiente{background:rgba(201,168,76,.1);color:var(--gold);border:1px solid rgba(201,168,76,.25)}
.b-error{background:rgba(176,96,96,.15);color:var(--red2);border:1px solid rgba(176,96,96,.3)}
.b-anulada{background:rgba(82,75,64,.2);color:var(--text3);border:1px solid var(--border)}
.b-activo{background:rgba(90,154,110,.12);color:#6aba88;border:1px solid rgba(90,154,110,.25)}
.b-inactivo{background:rgba(82,75,64,.2);color:var(--text3);border:1px solid var(--border)}
.b-solicitud{background:rgba(201,168,76,.1);color:var(--gold);border:1px solid rgba(201,168,76,.25)}
.b-pagada{background:rgba(201,168,76,.1);color:var(--gold);border:1px solid rgba(201,168,76,.25)}
.b-revisar{background:rgba(176,120,64,.15);color:#c89050;border:1px solid rgba(176,120,64,.3)}

/* ACTIONS */
.ba{
  padding:3px 9px;background:transparent;border:1px solid var(--border2);
  color:var(--text3);cursor:pointer;font-size:9px;font-weight:700;
  letter-spacing:.05em;text-transform:uppercase;transition:.15s;margin-right:3px;
}
.ba:hover{border-color:var(--gold);color:var(--gold)}
.ba.ok:hover{border-color:var(--green);color:var(--green)}
.ba.no:hover{border-color:var(--red2);color:var(--red2)}

/* SECTION HEADER */
.sh{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.sh-t{font-family:var(--serif);font-size:14px;font-weight:800;color:var(--text)}
.sh-c{font-size:10px;color:var(--text3);margin-left:6px;font-family:var(--mono)}
.btn-exp{
  padding:5px 12px;background:transparent;border:1px solid var(--border2);
  color:var(--text3);font-size:10px;font-weight:700;letter-spacing:.06em;
  text-transform:uppercase;cursor:pointer;transition:.15s;
}
.btn-exp:hover{border-color:var(--gold);color:var(--gold)}

/* DATE ROW */
.dr{display:flex;align-items:center;gap:8px}
.dr span{font-size:10px;color:var(--text3)}

/* CHARTS */
.cr{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:20px}
.cb{background:var(--bg2);border:1px solid var(--border);padding:18px}
.ct{font-size:9px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--text3);margin-bottom:14px}
.bc{display:flex;flex-direction:column;gap:9px}
.bi{display:flex;align-items:center;gap:10px}
.bl{font-size:10px;color:var(--text2);width:110px;text-align:right;flex-shrink:0}
.bt{flex:1;height:5px;background:var(--bg4);overflow:hidden}
.bf{height:100%;background:var(--gold);transition:.4s}
.bf.g{background:var(--green)}
.bf.o{background:var(--orange)}
.bv{font-family:var(--mono);font-size:10px;color:var(--text2);width:80px}

/* TABS */
.tabs{display:flex;border-bottom:1px solid var(--border);margin-bottom:14px}
.tab{
  padding:8px 16px;font-size:10px;font-weight:700;letter-spacing:.08em;
  text-transform:uppercase;color:var(--text3);cursor:pointer;
  border-bottom:2px solid transparent;transition:.15s;
}
.tab:hover{color:var(--text2)}
.tab.active{color:var(--gold);border-bottom-color:var(--gold)}
.tc{display:none}
.tc.active{display:block}

/* MODAL */
.mo{
  display:none;position:fixed;inset:0;
  background:rgba(0,0,0,.82);z-index:100;
  align-items:center;justify-content:center;
}
.mo.open{display:flex}
.modal{
  background:var(--bg2);border:1px solid var(--border2);
  width:620px;max-width:95vw;max-height:88vh;overflow-y:auto;position:relative;
}
.modal::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent,var(--gold),transparent);
}
.mh{
  padding:18px 22px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
}
.mt{font-family:var(--serif);font-size:15px;font-weight:800;color:var(--text)}
.mc{background:none;border:none;color:var(--text3);cursor:pointer;font-size:18px;transition:.15s}
.mc:hover{color:var(--text)}
.mb{padding:22px}
.dg{display:grid;grid-template-columns:1fr 1fr;gap:9px}
.di{border:1px solid var(--border);padding:10px 13px;background:var(--bg3)}
.dl{font-size:8.5px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--text3);margin-bottom:5px}
.dv{font-size:12px;color:var(--text);font-family:var(--mono)}
textarea.oi{
  width:100%;background:var(--bg3);border:1px solid var(--border2);
  color:var(--text);font-size:12px;padding:9px;resize:vertical;
  min-height:80px;outline:none;margin-top:12px;transition:.15s;
}
textarea.oi:focus{border-color:var(--gold)}

/* INFO ROW */
.ir{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px}
.ic2{background:var(--bg2);border:1px solid var(--border2);padding:4px 12px;font-size:10px;color:var(--text2)}
.ic2 b{color:var(--gold);font-family:var(--mono)}

/* AUDIT */
.ai{border-left:2px solid var(--border2);padding:11px 15px;margin-bottom:8px;background:var(--bg2);transition:.15s}
.ai:hover{border-left-color:var(--gold)}
.am{font-size:9px;color:var(--text3);margin-bottom:4px;font-family:var(--mono)}
.ad{font-size:12.5px;color:var(--text2)}
.adf{font-family:var(--mono);font-size:10px;margin-top:5px}
.adf .old{color:var(--red2)}
.adf .nw{color:var(--green)}

/* DIVIDER */
.gd{height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);opacity:.2;margin:18px 0}

/* TOAST */
.toast{
  position:fixed;bottom:22px;right:22px;
  background:var(--bg3);border:1px solid var(--border2);
  padding:10px 18px;font-size:11px;font-weight:700;letter-spacing:.05em;
  color:var(--text);z-index:999;transform:translateX(130%);transition:.3s;
}
.toast.show{transform:translateX(0)}
.toast.success{border-color:var(--gold);color:var(--gold)}
.toast.error{border-color:var(--red2);color:var(--red2)}
</style>
</head>
<body>

<!-- LOGIN -->
<div id="login-screen">
  <div class="login-box">
    <div class="login-logo"><em>Legal</em>AI ARG</div>
    <div class="login-sub">Panel Owner · Acceso restringido</div>
    <div class="fg">
      <label>Clave de acceso</label>
      <input type="password" id="lk" placeholder="••••••••••" autocomplete="off">
    </div>
    <button class="btn-gold" onclick="doLogin()">Ingresar</button>
    <div class="login-err" id="lerr">Clave incorrecta</div>
  </div>
</div>

<!-- APP -->
<div id="app" style="display:flex">

  <!-- SIDEBAR -->
  <div id="sidebar">
    <div class="sl">
      <div class="brand"><em>Legal</em>AI ARG</div>
      <div class="brand-sub">Owner Panel</div>
    </div>
    <nav class="snav">
      <div class="nsec">Principal</div>
      <div class="ni active" onclick="goto('dashboard',this)"><span class="ic">◈</span><span>Dashboard</span></div>
      <div class="ni" onclick="goto('operaciones',this)"><span class="ic">≡</span><span>Operaciones</span></div>
      <div class="nsec">Gestión</div>
      <div class="ni" onclick="goto('afiliados',this)"><span class="ic">◎</span><span>Afiliados</span></div>
      <div class="ni" onclick="goto('comisiones',this)"><span class="ic">$</span><span>Comisiones</span></div>
      <div class="nsec">Sistema</div>
      <div class="ni" onclick="goto('logs',this)"><span class="ic">▷</span><span>Logs / Errores</span></div>
      <div class="ni" onclick="goto('auditoria',this)"><span class="ic">◫</span><span>Auditoría</span></div>
    </nav>
    <div class="sb">
      <div class="sb-user">Owner</div>
      <button class="btn-logout" onclick="doLogout()">Cerrar sesión</button>
    </div>
  </div>

  <!-- MAIN -->
  <div id="main">
    <div id="topbar">
      <div class="tb-title" id="tbt">Dashboard</div>
      <div class="tb-r">
        <div class="live">Live</div>
        <div class="tb-date" id="tbd"></div>
      </div>
    </div>

    <div id="content">

      <!-- DASHBOARD -->
      <div class="page active" id="page-dashboard">
        <div class="ph">
          <div>
            <div class="ph-title">Resumen <em>operacional</em></div>
            <div class="ph-sub">Métricas en tiempo real por período</div>
          </div>
          <div class="dr">
            <div class="fg2"><label>Desde</label><input type="date" id="dd" value="2025-01-01"></div>
            <span>—</span>
            <div class="fg2"><label>Hasta</label><input type="date" id="dh" value="2025-12-31"></div>
            <button class="btn-f" onclick="renderDash()">Aplicar</button>
          </div>
        </div>
        <div class="cards" id="dk"></div>
        <div class="cr" id="dc"></div>
        <div class="sh"><div><span class="sh-t">Últimas operaciones</span></div></div>
        <div class="tw" id="dr2"></div>
      </div>

      <!-- OPERACIONES -->
      <div class="page" id="page-operaciones">
        <div class="ph">
          <div>
            <div class="ph-title">Inventario de <em>operaciones</em></div>
            <div class="ph-sub">Todos los eventos del sistema</div>
          </div>
          <button class="btn-exp" onclick="exportCSV('ops')">↓ Exportar CSV</button>
        </div>
        <div class="sb2"><input type="text" id="os" placeholder="Buscar por email, ID, código, afiliado, producto..." oninput="filterOps()"></div>
        <div class="fb">
          <div class="fg2"><label>Desde</label><input type="date" id="od" value="2025-01-01"></div>
          <div class="fg2"><label>Hasta</label><input type="date" id="oh" value="2025-12-31"></div>
          <div class="fg2"><label>Tipo</label>
            <select id="ot"><option value="">Todos</option><option>venta</option><option>activacion</option><option>generacion</option><option>upgrade</option><option>afiliado</option><option>error</option></select>
          </div>
          <div class="fg2"><label>Estado</label>
            <select id="oe"><option value="">Todos</option><option>Confirmada</option><option>Pendiente</option><option>Error</option><option>Anulada</option><option>Revisada</option></select>
          </div>
          <div class="fg2"><label>Método</label>
            <select id="om"><option value="">Todos</option><option>MercadoPago</option><option>NOWPayments</option></select>
          </div>
          <div class="fg2"><label>Producto</label>
            <select id="op2"><option value="">Todos</option><option>Plan Básico</option><option>Plan Pro</option><option>Plan Enterprise</option><option>Pack Documentos</option><option>Documento único</option></select>
          </div>
          <div class="fg2"><label>Afiliado</label>
            <select id="oa"><option value="">Todos</option><option value="si">Con afiliado</option><option value="no">Sin afiliado</option></select>
          </div>
          <div class="fg2"><label>Error</label>
            <select id="oer"><option value="">Todos</option><option value="si">Con error</option><option value="no">Sin error</option></select>
          </div>
          <button class="btn-f" onclick="filterOps()">Filtrar</button>
          <button class="btn-cl" onclick="clearOps()">Limpiar</button>
        </div>
        <div class="sh"><div><span class="sh-t">Eventos</span><span class="sh-c" id="oc"></span></div></div>
        <div class="tw" id="ot2"></div>
      </div>

      <!-- AFILIADOS -->
      <div class="page" id="page-afiliados">
        <div class="ph">
          <div>
            <div class="ph-title">Programa de <em>afiliados</em></div>
            <div class="ph-sub">Gestión de referidos y solicitudes</div>
          </div>
