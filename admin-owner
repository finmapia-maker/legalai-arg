function renderDash(){
  const desde=document.getElementById('dd').value,hasta=document.getElementById('dh').value;
  const ops=OPS.filter(o=>o.fecha>=desde&&o.fecha<=hasta+'z');
  const v=ops.filter(o=>o.tipo==='venta'&&o.estado==='Confirmada');
  const tARS=v.filter(o=>o.moneda==='ARS').reduce((s,o)=>s+o.monto,0);
  const tUSDT=v.filter(o=>o.moneda==='USDT').reduce((s,o)=>s+o.monto,0);
  const pARS=COMS.filter(c=>c.estado==='Pendiente'&&c.mon_c==='ARS').reduce((s,c)=>s+c.monto_c,0);
  const pUSDT=COMS.filter(c=>c.estado==='Pendiente'&&c.mon_c==='USDT').reduce((s,c)=>s+c.monto_c,0);
  const err=ops.filter(o=>o.error_flag).length;

  document.getElementById('dk').innerHTML=[
    {l:'Facturación ARS',v:'$'+f(tARS),s:'período seleccionado',c:'gold'},
    {l:'Facturación USDT',v:tUSDT.toFixed(4)+' USDT',s:'período',c:'gold'},
    {l:'Ventas confirmadas',v:v.length,s:'transacciones'},
