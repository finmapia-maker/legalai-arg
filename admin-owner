        <button class="ba ok" onclick="aprob('${s.email}')">Aprobar</button>
        <button class="ba no" onclick="toast('Solicitud rechazada','success')">Rechazar</button>
      </td>
    </tr>`).join('')}</tbody></table>`;
}
function renderAStats(){
  const ac=AFIL.filter(a=>a.estado==='Activo').length;
  const tot=AFIL.reduce((s,a)=>s+a.total_ars,0);
  const pen=AFIL.reduce((s,a)=>s+a.pendiente_ars,0);
  document.getElementById('astats').innerHTML=[
    {l:'Afiliados activos',v:ac,c:'green'},
    {l:'Total comisiones ARS',v:'$'+f(tot),c:'gold'},
    {l:'Com. pendientes ARS',v:'$'+f(pen),c:'dim'},
    {l:'Total clientes referidos',v:AFIL.reduce((s,a)=>s+a.clientes_referidos,0)},
  ].map(k=>`<div class="card"><div class="cl">${k.l}</div><div class="cv ${k.c||''}">${k.v}</div></div>`).join('');
}
function togAfil(cod){
  const a=AFIL.find(x=>x.codigo===cod);if(!a)return;
  const p=a.estado;a.estado=a.estado==='Activo'?'Inactivo':'Activo';
  logA('Cambio estado afiliado','estado',p,a.estado,'AFIL-'+cod,'');
  toast(a.nombre+' → '+a.estado,'success');renderAfil();
}
function verAD(cod){
  const a=AFIL.find(x=>x.codigo===cod);if(!a)return;
  document.getElementById('m-det-t').textContent='Afiliado — '+a.codigo;
  const coms=COMS.filter(c=>c.afil_c===cod);
  document.getElementById('m-det-b').innerHTML=`
    <div class="dg">
      ${[['Nombre',a.nombre],['Email',a.email],['Código',a.codigo],['Estado',bdg(a.estado)],['% Comisión',a.porcentaje+'%'],['Clientes',a.clientes_referidos],['Total ARS','$'+f(a.total_ars)],['Pendiente ARS','$'+f(a.pendiente_ars)]].map(([l,v])=>`<div class="di"><div class="dl">${l}</div><div class="dv">${v}</div></div>`).join('')}
    </div>
    <div class="gd"></div>
    <div style="font-size:9px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--text3);margin-bottom:10px">Comisiones (${coms.length})</div>
    ${coms.map(c=>`<div style="background:var(--bg3);border:1px solid var(--border);padding:9px 13px;margin-bottom:7px;font-size:11px;display:flex;align-items:center;justify-content:space-between;gap:10px">
      <span style="font-family:var(--mono);color:var(--text3)">${c.fecha}</span>
      <span>${c.producto}</span>
      <span style="font-family:var(--mono);color:var(--gold)">${ms(c.monto_c,c.mon_c)}</span>
      ${bdg(c.estado)}
      <button class="ba ok" onclick="marcarPagada('${c.id}')">Pagar</button>
    </div>`).join('')}
  `;
  openM('m-det');
}
function aprob(email){
  const s=SOLS.find(x=>x.email===email);if(!s)return;
  AFIL.push({codigo:s.nombre.split(' ')[0].toUpperCase()+'22',nombre:s.nombre,email:s.email,estado:'Activo',porcentaje:20,clientes_referidos:0,total_ars:0,total_usdt:0,pendiente_ars:0,fecha_alta:new Date().toISOString().split('T')[0]});
  SOLS.splice(SOLS.indexOf(s),1);
  logA('Solicitud aprobada','estado','Solicitud','Activo','AFIL-'+email,'');
  toast('Solicitud aprobada','success');renderAfil();
}
function crearAfil(){
  const n=document.getElementById('nn').value,e=document.getElementById('ne').value,c=document.getElementById('nc').value,p=parseInt(document.getElementById('np').value);
  if(!n||!e||!c){toast('Completá todos los campos','error');return}
  AFIL.push({codigo:c,nombre:n,email:e,estado:'Activo',porcentaje:p,clientes_referidos:0,total_ars:0,total_usdt:0,pendiente_ars:0,fecha_alta:new Date().toISOString().split('T')[0]});
  logA('Creación afiliado','estado','','Activo','AFIL-'+c,'');
  toast('Afiliado creado','success');closeM('m-naf');renderAfil();
}

// ─ COMISIONES ─
function renderCom(){filterCom()}
function filterCom(){
  const cd=document.getElementById('cd')?.value||'';
  const ch=document.getElementById('ch')?.value||'';
  const ce=document.getElementById('ce')?.value||'';
  const ca=(document.getElementById('ca')?.value||'').toLowerCase();
  const data=COMS.filter(c=>{
    if(cd&&c.fecha<cd)return false;
    if(ch&&c.fecha>ch)return false;
    if(ce&&c.estado!==ce)return false;
    if(ca&&!(c.afil_e.includes(ca)||c.afil_c.toLowerCase().includes(ca)))return false;
    return true;
  });
  const pARS=data.filter(c=>c.estado==='Pendiente'&&c.mon_c==='ARS').reduce((s,c)=>s+c.monto_c,0);
  const pgARS=data.filter(c=>c.estado==='Pagada'&&c.mon_c==='ARS').reduce((s,c)=>s+c.monto_c,0);
  const pUSDT=data.filter(c=>c.estado==='Pendiente'&&c.mon_c==='USDT').reduce((s,c)=>s+c.monto_c,0);
  document.getElementById('csum').innerHTML=`
    <div class="ic2">Pendiente ARS <b>$${f(pARS)}</b></div>
    <div class="ic2">Pagada ARS <b>$${f(pgARS)}</b></div>
    <div class="ic2">Pendiente USDT <b>${pUSDT} USDT</b></div>
    <div class="ic2">Registros <b>${data.length}</b></div>`;
  document.getElementById('cc').textContent=` — ${data.length} registros`;
  document.getElementById('ct2').innerHTML=`<table>
    <thead><tr><th>ID</th><th>Fecha</th><th>Afiliado</th><th>Cliente</th><th>Producto</th><th>Venta</th><th>%</th><th>Comisión</th><th>Estado</th><th>Renovación</th><th>Acciones</th></tr></thead>
    <tbody>${data.map(c=>`<tr>
      <td style="font-family:var(--mono);font-size:10px;color:var(--text3)">${c.id}</td>
      <td style="font-family:var(--mono);font-size:10px">${c.fecha}</td>
      <td><div style="font-size:12px">${c.afil_n}</div><div style="font-size:10px;color:var(--gold);font-family:var(--mono)">${c.afil_c}</div></td>
      <td style="font-size:11px">${c.cli}</td>
      <td style="font-size:11px">${c.producto}</td>
      <td style="font-family:var(--mono)">${ms(c.monto_v,c.mon_v)}</td>
      <td style="font-family:var(--mono);text-align:center">${c.pct}%</td>
      <td style="font-family:var(--mono);font-weight:700">${ms(c.monto_c,c.mon_c)}</td>
      <td>${bdg(c.estado)}</td>
      <td style="text-align:center;font-size:10px">${c.renovacion?'<span style="color:var(--gold)">Sí</span>':'—'}</td>
      <td>${c.estado==='Pendiente'?`<button class="ba ok" onclick="marcarPagada('${c.id}')">Pagar</button>`:''}</td>
    </tr>`).join('')}</tbody></table>`;
}
function clearCom(){['ce','ca'].forEach(id=>{const el=document.getElementById(id);if(el)el.value=''});filterCom()}
function marcarPagada(id){
  const c=COMS.find(x=>x.id===id);if(!c||c.estado==='Pagada'){toast('Ya está pagada','error');return}
  const p=c.estado;c.estado='Pagada';
  const a=AFIL.find(x=>x.codigo===c.afil_c);
  if(a&&c.mon_c==='ARS')a.pendiente_ars=Math.max(0,a.pendiente_ars-c.monto_c);
  logA('Comisión marcada pagada','estado',p,'Pagada',c.id,'');
  toast(c.id+' → Pagada','success');renderCom();renderAfil();renderDash();closeM('m-det');
}

