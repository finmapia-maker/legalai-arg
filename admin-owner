function ds(){return '<span style="color:var(--text3)">—</span>'}
function em(){return '<div style="padding:28px;text-align:center;color:var(--text3);font-size:12px">Sin registros</div>'}

// ─ DETALLE ─
function verDet(id){
  const o=OPS.find(x=>x.id===id);if(!o)return;
  document.getElementById('m-det-t').textContent='Evento — '+o.id;
  const flds=[
    ['ID',o.id],['Fecha',o.fecha],['Tipo',o.tipo+' / '+o.subtipo],['Estado',bdg(o.estado)],
    ['Email',o.email||'—'],['Nombre',o.nombre||'—'],['Producto',o.producto||'—'],['Plan',o.plan||'—'],
    ['Monto',o.monto?ms(o.monto,o.moneda):'—'],['Método',o.metodo_pago||'—'],
    ['Payment ID',o.payment_id||'—'],['Order ID',o.order_id||'—'],['Invoice ID',o.invoice_id||'—'],['Código',o.codigo||'—'],
    ['Afiliado ref',o.afiliado_ref||'—'],['Afiliado email',o.afiliado_email||'—'],
    ['Comisión',o.comision_monto?ms(o.comision_monto,o.comision_moneda):'—'],['Est. comisión',o.comision_estado||'—'],
    ['Doc generado',o.documento_generado?'✓ Sí':'No'],['Error',o.error_flag?'⚠ '+o.error_tipo:'No'],
    ['Det. error',o.error_detalle||'—'],['Actualizado',o.updated_at],
  ];
  document.getElementById('m-det-b').innerHTML=`
    <div class="dg">${flds.map(([l,v])=>`<div class="di"><div class="dl">${l}</div><div class="dv">${v}</div></div>`).join('')}</div>
    ${o.observaciones?`<div style="margin-top:12px;padding:10px 13px;background:var(--bg3);border:1px solid var(--border2);font-size:11px;color:var(--text2)"><span style="color:var(--text3)">Observaciones:</span><br>${o.observaciones}</div>`:''}
    <div class="gd"></div>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
      <button class="btn-f" style="font-size:10px;padding:7px 14px" onclick="mRevisada('${o.id}')">Marcar revisada</button>
      <button class="btn-exp" onclick="toast('Email reenviado (simulado)','success')">Reenviar email</button>
      <button class="btn-exp" onclick="cp('${o.id}')">Copiar ID</button>
    </div>
    <textarea class="oi" id="tobs-${o.id}" placeholder="Agregar observación..."></textarea>
    <button class="ba" style="margin-top:8px" onclick="gObs('${o.id}')">Guardar observación</button>
  `;
  openM('m-det');
}
function mRevisada(id){
  const o=OPS.find(x=>x.id===id);if(!o)return;
  o.estado='Revisada';logA('Marcar revisada','estado','Confirmada','Revisada',id,'');
  toast('Evento marcado como revisado','success');renderOps();closeM('m-det');
}
function gObs(id){
  const t=document.getElementById('tobs-'+id)?.value;if(!t?.trim()){toast('Escribí una observación','error');return}
  const o=OPS.find(x=>x.id===id);if(o){o.observaciones=t;logA('Observación','observaciones','',t,id,'');toast('Observación guardada','success')}
}

// ─ AFILIADOS ─
function renderAfil(){filterAfil();renderSols();renderAStats()}
function filterAfil(){
  const s=(document.getElementById('as')?.value||'').toLowerCase();
  const e=document.getElementById('ae')?.value||'';
  const data=AFIL.filter(a=>{
    if(e&&a.estado!==e)return false;
    if(s&&![a.codigo,a.nombre,a.email].join(' ').toLowerCase().includes(s))return false;
    return true;
  });
  document.getElementById('at2').innerHTML=`<table>
    <thead><tr><th>Código</th><th>Nombre</th><th>Email</th><th>Estado</th><th>%</th><th>Clientes</th><th>Total ARS</th><th>Total USDT</th><th>Pendiente ARS</th><th>Alta</th><th>Acciones</th></tr></thead>
    <tbody>${data.map(a=>`<tr>
      <td style="font-family:var(--mono);color:var(--gold);font-size:11px">${a.codigo}</td>
      <td>${a.nombre}</td><td style="font-size:11px">${a.email}</td>
      <td>${bdg(a.estado)}</td>
      <td style="font-family:var(--mono);text-align:center">${a.porcentaje}%</td>
      <td style="text-align:center">${a.clientes_referidos}</td>
      <td style="font-family:var(--mono)">$${f(a.total_ars)}</td>
      <td style="font-family:var(--mono)">${a.total_usdt} USDT</td>
      <td style="font-family:var(--mono);color:var(--gold)">$${f(a.pendiente_ars)}</td>
      <td style="font-size:10px;color:var(--text3)">${a.fecha_alta}</td>
      <td>
        <button class="ba" onclick="verAD('${a.codigo}')">Ver</button>
        <button class="ba ${a.estado==='Activo'?'no':'ok'}" onclick="togAfil('${a.codigo}')">${a.estado==='Activo'?'Desactivar':'Activar'}</button>
      </td>
    </tr>`).join('')}</tbody></table>`;
}
function renderSols(){
  document.getElementById('asol').innerHTML=`<table>
    <thead><tr><th>Fecha</th><th>Nombre</th><th>Email</th><th>Descripción</th><th>Estado</th><th>Acciones</th></tr></thead>
    <tbody>${SOLS.map(s=>`<tr>
      <td style="font-size:11px;color:var(--text3)">${s.fecha}</td>
      <td>${s.nombre}</td><td style="font-size:11px">${s.email}</td>
      <td style="font-size:11px">${s.descripcion}</td>
