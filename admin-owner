    {l:'Afiliados activos',v:AFIL.filter(a=>a.estado==='Activo').length,s:'en el programa',c:'green'},
  ].map(k=>`<div class="card"><div class="cl">${k.l}</div><div class="cv ${k.c||''}">${k.v}</div><div class="cs">${k.s}</div></div>`).join('');

  const byP={};v.forEach(o=>{byP[o.producto]=(byP[o.producto]||0)+(o.moneda==='ARS'?o.monto:0)});
  const mxP=Math.max(...Object.values(byP),1);
