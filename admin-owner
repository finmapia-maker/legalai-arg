// ─ EXPORT ─
function exportCSV(tipo){
  let data,hdrs,rows;
  if(tipo==='ops'){data=OPS;hdrs=['id','fecha','tipo','subtipo','estado','email','nombre','producto','plan','monto','moneda','metodo_pago','afiliado_ref','comision_monto','comision_moneda','comision_estado','payment_id','error_flag','observaciones'];}
  else if(tipo==='afiliados'){data=AFIL;hdrs=['codigo','nombre','email','estado','porcentaje','clientes_referidos','total_ars','total_usdt','pendiente_ars','fecha_alta'];}
  else{data=COMS;hdrs=['id','fecha','afil_c','afil_n','cli','producto','monto_v','mon_v','pct','monto_c','mon_c','estado','renovacion'];}
  rows=data.map(d=>hdrs.map(h=>JSON.stringify(d[h]??'')).join(','));
  const a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob([[hdrs.join(','),...rows].join('\n')],{type:'text/csv'}));
  a.download=`legalai-${tipo}-${new Date().toISOString().split('T')[0]}.csv`;a.click();
  toast('CSV exportado','success');
}

// ─ UTILS ─
function ms(m,c){
  if(c==='ARS')return '$'+f(m)+' <span style="font-size:9px;color:var(--text3)">ARS</span>';
  if(c==='USDT')return m+' <span style="font-size:9px;color:var(--gold)">USDT</span>';
  return m+(c?' '+c:'');
}
function f(n){return Number(n).toLocaleString('es-AR')}
function bdg(e){
  const m={Confirmada:'b-confirmada',Pendiente:'b-pendiente',Error:'b-error',Anulada:'b-anulada',Activo:'b-activo',Inactivo:'b-inactivo',Solicitud:'b-solicitud',Pagada:'b-pagada',Revisar:'b-revisar',Revisada:'b-inactivo'};
  return `<span class="badge ${m[e]||'b-pendiente'}">${e}</span>`;
}
function openM(id){document.getElementById(id).classList.add('open')}
function closeM(id){document.getElementById(id).classList.remove('open')}
document.querySelectorAll('.mo').forEach(m=>m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('open')}));
function toast(msg,type=''){
  const t=document.getElementById('toast');
  t.textContent=msg;t.className='toast'+(type?' '+type:'');
  t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2800);
}
function cp(txt){navigator.clipboard?.writeText(txt).then(()=>toast('Copiado','success'))}
