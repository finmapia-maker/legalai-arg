    <div class="cb"><div class="ct">Ventas por método de pago</div><div class="bc">${Object.entries(byM).map(([m,v])=>`<div class="bi"><div class="bl">${m}</div><div class="bt"><div class="bf g" style="width:${v/mxM*100}%"></div></div><div class="bv">$${f(v)}</div></div>`).join('')||nd()}</div></div>
    <div class="cb"><div class="ct">Ventas por afiliado — ARS</div><div class="bc">${Object.entries(byA).length?Object.entries(byA).map(([a,v])=>`<div class="bi"><div class="bl">${a}</div><div class="bt"><div class="bf o" style="width:${v/mxA*100}%"></div></div><div class="bv">$${f(v)}</div></div>`).join(''):nd()}</div></div>
    <div class="cb"><div class="ct">Estado comisiones — ARS</div><div class="bc">
      <div class="bi"><div class="bl">Pendiente</div><div class="bt"><div class="bf" style="width:${pARS/mxC*100}%"></div></div><div class="bv">$${f(pARS)}</div></div>
      <div class="bi"><div class="bl">Pagada</div><div class="bt"><div class="bf g" style="width:${cPag/mxC*100}%"></div></div><div class="bv">$${f(cPag)}</div></div>
