function renderAudit(){
  document.getElementById('alist').innerHTML=ALOG.length
    ?ALOG.map(a=>`<div class="ai">
        <div class="am">${a.fecha} · ${a.u} · Ref: <span style="color:var(--gold)">${a.ref}</span></div>
