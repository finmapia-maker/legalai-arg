function renderOps(){filterOps()}
function filterOps(){
  const s=(document.getElementById('os')?.value||'').toLowerCase();
  const od=document.getElementById('od')?.value||'';
  const oh=document.getElementById('oh')?.value||'';
  const ot=document.getElementById('ot')?.value||'';
  const oe=document.getElementById('oe')?.value||'';
  const om=document.getElementById('om')?.value||'';
  const op2=document.getElementById('op2')?.value||'';
  const oa=document.getElementById('oa')?.value||'';
  const oer=document.getElementById('oer')?.value||'';
  const data=OPS.filter(o=>{
    if(od&&o.fecha<od)return false;
    if(oh&&o.fecha>oh+'z')return false;
    if(ot&&o.tipo!==ot)return false;
    if(oe&&o.estado!==oe)return false;
    if(om&&o.metodo_pago!==om)return false;
    if(op2&&o.producto!==op2)return false;
    if(oa==='si'&&!o.afiliado_ref)return false;
    if(oa==='no'&&o.afiliado_ref)return false;
    if(oer==='si'&&!o.error_flag)return false;
    if(oer==='no'&&o.error_flag)return false;
    if(s&&![o.id,o.email,o.nombre,o.producto,o.afiliado_ref,o.payment_id,o.order_id,o.codigo].join(' ').toLowerCase().includes(s))return false;
    return true;
  });
  document.getElementById('oc').textContent=` — ${data.length} registros`;
  document.getElementById('ot2').innerHTML=buildOpsT(data,false);
}
function clearOps(){['os','ot','oe','om','op2','oa','oer'].forEach(id=>{const el=document.getElementById(id);if(el)el.value=''});filterOps()}
