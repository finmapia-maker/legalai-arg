<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Afiliados — LegalAI Arg</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --gold:       #c9a84c;
    --gold-light: #e8c96a;
    --gold-dim:   #7a6020;
    --bg:         #0a0a0f;
    --surface:    #16161f;
    --surface2:   #1e1e2a;
    --border:     #23232f;
    --border2:    #2e2e3e;
    --text:       #e8e8f0;
    --muted:      #8888a0;
    --faint:      #444460;
    --green:      #4caf7a;
    --green-bg:   #0e2018;
    --red:        #e05c5c;
    --red-bg:     #1f0e0e;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }

  /* ── Auth screen ── */
  .auth-wrap { display: flex; align-items: center; justify-content: center; min-height: 100vh; }
  .auth-card { background: var(--surface); border: 1px solid var(--border2); border-radius: 20px; padding: 48px 40px; width: 100%; max-width: 380px; text-align: center; }
  .auth-logo { font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 700; color: var(--gold); margin-bottom: 4px; }
  .auth-sub { font-size: 13px; color: var(--muted); margin-bottom: 32px; }
  .auth-label { font-size: 12px; color: var(--muted); text-align: left; display: block; margin-bottom: 6px; letter-spacing: .04em; }
  .auth-input { width: 100%; background: var(--bg); border: 1px solid var(--border2); border-radius: 10px; padding: 12px 16px; font-family: 'DM Mono', monospace; font-size: 14px; color: var(--text); outline: none; transition: border-color .2s; }
  .auth-input:focus { border-color: var(--gold); }
  .auth-btn { width: 100%; margin-top: 20px; background: var(--gold); color: #000; border: none; border-radius: 10px; padding: 14px; font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 700; cursor: pointer; transition: opacity .2s; }
  .auth-btn:hover { opacity: .88; }
  .auth-error { margin-top: 14px; font-size: 13px; color: var(--red); display: none; }

  /* ── Layout ── */
  .header { border-bottom: 1px solid var(--border); padding: 16px 32px; display: flex; align-items: center; justify-content: space-between; background: var(--surface); }
  .header-logo { font-family: 'Playfair Display', serif; font-size: 18px; font-weight: 700; color: var(--gold); }
  .header-badge { font-size: 11px; font-weight: 600; color: var(--muted); background: var(--border); padding: 3px 10px; border-radius: 20px; letter-spacing: .06em; text-transform: uppercase; margin-left: 12px; }
  .header-actions { display: flex; gap: 10px; align-items: center; }
  .btn { border: none; border-radius: 8px; padding: 9px 18px; font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 600; cursor: pointer; transition: opacity .2s, transform .1s; }
  .btn:hover { opacity: .88; }
  .btn:active { transform: scale(.97); }
  .btn-gold { background: var(--gold); color: #000; }
  .btn-outline { background: transparent; color: var(--muted); border: 1px solid var(--border2); }
  .btn-outline:hover { color: var(--text); border-color: var(--border); }
  .btn-red { background: var(--red-bg); color: var(--red); border: 1px solid #3a1010; }
  .btn-green { background: var(--green-bg); color: var(--green); border: 1px solid #1a4030; }
  .btn-sm { padding: 6px 12px; font-size: 12px; }

  .main { max-width: 1100px; margin: 0 auto; padding: 36px 24px; }

  /* ── Stats row ── */
  .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 32px; }
  @media(max-width:700px) { .stats-row { grid-template-columns: 1fr 1fr; } }
  .stat-card { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 20px 22px; }
  .stat-ey { font-size: 11px; font-weight: 600; color: var(--faint); letter-spacing: .08em; text-transform: uppercase; margin-bottom: 8px; }
  .stat-val { font-family: 'DM Mono', monospace; font-size: 26px; color: var(--gold); }
  .stat-val.green { color: var(--green); }
  .stat-val.red { color: var(--red); }

  /* ── Section ── */
  .sec-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
  .sec-title { font-family: 'Playfair Display', serif; font-size: 20px; font-weight: 600; color: var(--text); }

  /* ── Table ── */
  .table-wrap { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; overflow: hidden; margin-bottom: 36px; }
  .t-head { display: grid; padding: 12px 20px; background: var(--surface2); border-bottom: 1px solid var(--border); }
  .th { font-size: 11px; font-weight: 600; color: var(--faint); letter-spacing: .07em; text-transform: uppercase; }
  .t-row { display: grid; padding: 14px 20px; border-bottom: 1px solid var(--border); align-items: center; transition: background .15s; cursor: pointer; }
  .t-row:last-child { border-bottom: none; }
  .t-row:hover { background: var(--surface2); }

  /* Afiliados list cols: nombre / ref / comisión / pending / cobrado / estado / acciones */
  .aff-cols { grid-template-columns: 1.4fr 100px 70px 90px 90px 80px 1fr; }

  .cell-name { font-size: 13px; font-weight: 600; color: var(--text); }
  .cell-sub { font-size: 11px; color: var(--faint); margin-top: 2px; }
  .cell-ref { font-family: 'DM Mono', monospace; font-size: 12px; color: var(--gold-light); }
  .cell-pct { font-size: 13px; color: var(--muted); }
  .cell-money { font-family: 'DM Mono', monospace; font-size: 13px; }
  .money-pending { color: var(--gold); }
  .money-paid { color: var(--green); }

  .pill { display: inline-flex; align-items: center; gap: 5px; font-size: 11px; font-weight: 600; padding: 4px 10px; border-radius: 20px; }
  .pill.active { background: var(--green-bg); color: var(--green); border: 1px solid #1a4030; }
  .pill.inactive { background: var(--red-bg); color: var(--red); border: 1px solid #3a1010; }
  .pill-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }

  .cell-actions { display: flex; gap: 8px; flex-wrap: wrap; }

  /* ── Modal ── */
  .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.75); display: none; align-items: center; justify-content: center; z-index: 100; padding: 20px; }
  .modal-overlay.open { display: flex; }
  .modal { background: var(--surface); border: 1px solid var(--border2); border-radius: 20px; width: 100%; max-width: 520px; max-height: 90vh; overflow-y: auto; }
  .modal-header { padding: 24px 28px 20px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
  .modal-title { font-family: 'Playfair Display', serif; font-size: 18px; font-weight: 600; color: var(--text); }
  .modal-close { background: none; border: none; color: var(--muted); font-size: 20px; cursor: pointer; padding: 4px 8px; border-radius: 6px; }
  .modal-close:hover { background: var(--border); color: var(--text); }
  .modal-body { padding: 24px 28px; }
  .modal-footer { padding: 16px 28px 24px; display: flex; gap: 10px; justify-content: flex-end; border-top: 1px solid var(--border); }

  .form-group { margin-bottom: 18px; }
  .form-label { font-size: 12px; font-weight: 600; color: var(--muted); letter-spacing: .04em; text-transform: uppercase; display: block; margin-bottom: 7px; }
  .form-input { width: 100%; background: var(--bg); border: 1px solid var(--border2); border-radius: 10px; padding: 11px 14px; font-family: 'DM Sans', sans-serif; font-size: 14px; color: var(--text); outline: none; transition: border-color .2s; }
  .form-input:focus { border-color: var(--gold); }
  .form-hint { font-size: 11px; color: var(--faint); margin-top: 5px; line-height: 1.5; }

  /* Info boxes en modal */
  .info-row { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid var(--border); font-size: 13px; }
  .info-row:last-child { border-bottom: none; }
  .info-key { color: var(--muted); }
  .info-val { color: var(--text); font-weight: 600; }
  .info-val.mono { font-family: 'DM Mono', monospace; color: var(--gold-light); }
  .info-val.green { color: var(--green); }
  .info-val.gold { color: var(--gold); }

  /* Conversiones en modal */
  .conv-mini { background: var(--bg); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; margin-top: 16px; }
  .conv-mini-head { display: grid; grid-template-columns: 1fr 80px 70px 70px 70px; padding: 10px 14px; background: var(--surface2); }
  .conv-mini-row { display: grid; grid-template-columns: 1fr 80px 70px 70px 70px; padding: 11px 14px; border-top: 1px solid var(--border); font-size: 12px; align-items: center; }
  .conv-mini-row:hover { background: var(--surface2); }

  /* Toast */
  .toast { position: fixed; bottom: 28px; right: 28px; background: var(--surface2); border: 1px solid var(--border2); border-radius: 12px; padding: 14px 20px; font-size: 13px; color: var(--text); box-shadow: 0 8px 32px rgba(0,0,0,.5); transform: translateY(80px); opacity: 0; transition: all .3s; z-index: 200; max-width: 300px; }
  .toast.show { transform: translateY(0); opacity: 1; }
  .toast.ok { border-left: 3px solid var(--green); }
  .toast.err { border-left: 3px solid var(--red); }

  .loading-row { padding: 36px; text-align: center; color: var(--faint); font-size: 14px; }
  .spinner-sm { display: inline-block; width: 20px; height: 20px; border: 2px solid var(--border2); border-top-color: var(--gold); border-radius: 50%; animation: spin .8s linear infinite; vertical-align: middle; margin-right: 8px; }
  @keyframes spin { to { transform: rotate(360deg); } }

  .url-box { background: var(--bg); border: 1px solid var(--border2); border-radius: 8px; padding: 10px 14px; font-family: 'DM Mono', monospace; font-size: 12px; color: var(--gold-light); word-break: break-all; margin-top: 8px; cursor: pointer; transition: border-color .2s; }
  .url-box:hover { border-color: var(--gold); }
</style>
</head>
<body>

<!-- Auth screen -->
<div id="authScreen" class="auth-wrap">
  <div class="auth-card">
    <p class="auth-logo">LegalAI Arg</p>
    <p class="auth-sub">Panel de Administración · Afiliados</p>
    <label class="auth-label">Admin Key</label>
    <input type="password" class="auth-input" id="authInput" placeholder="••••••••••••" onkeydown="if(event.key==='Enter')login()">
    <button class="btn btn-gold auth-btn" onclick="login()">Ingresar</button>
    <p class="auth-error" id="authError">Clave incorrecta</p>
  </div>
</div>

<!-- Panel principal -->
<div id="panel" style="display:none;">
  <header class="header">
    <div style="display:flex;align-items:center;">
      <span class="header-logo">LegalAI Arg</span>
      <span class="header-badge">Admin · Afiliados</span>
    </div>
    <div class="header-actions">
      <button class="btn btn-outline" onclick="cargarPanel()">↺ Actualizar</button>
      <button class="btn btn-gold" onclick="abrirModalCrear()">+ Nuevo afiliado</button>
    </div>
  </header>

  <div class="main">
    <!-- Stats -->
    <div class="stats-row">
      <div class="stat-card"><p class="stat-ey">Afiliados activos</p><p class="stat-val" id="sActivos">—</p></div>
      <div class="stat-card"><p class="stat-ey">Total conversiones</p><p class="stat-val" id="sConvs">—</p></div>
      <div class="stat-card"><p class="stat-ey">Total pendiente</p><p class="stat-val" id="sPending">—</p></div>
      <div class="stat-card"><p class="stat-ey">Total pagado</p><p class="stat-val green" id="sPaid">—</p></div>
    </div>

    <!-- Tabla afiliados -->
    <div class="sec-header">
      <h2 class="sec-title">Afiliados</h2>
    </div>
    <div class="table-wrap">
      <div class="t-head aff-cols">
        <span class="th">Nombre / Email</span>
        <span class="th">Código</span>
        <span class="th">Comisión</span>
        <span class="th">Pendiente</span>
        <span class="th">Cobrado</span>
        <span class="th">Estado</span>
        <span class="th">Acciones</span>
      </div>
      <div id="tablaAfiliados">
        <div class="loading-row"><span class="spinner-sm"></span>Cargando…</div>
      </div>
    </div>
  </div>
</div>

<!-- Modal Crear Afiliado -->
<div class="modal-overlay" id="modalCrear">
  <div class="modal">
    <div class="modal-header">
      <h3 class="modal-title">Nuevo afiliado</h3>
      <button class="modal-close" onclick="cerrarModal('modalCrear')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-label">Código de referido (REF)</label>
        <input type="text" class="form-input" id="crearRef" placeholder="LAUTARO20" style="text-transform:uppercase;">
        <p class="form-hint">Letras y números, sin espacios. Ej: JUAN30, MARIA20. Esto aparece en el link: /planes.html?ref=CODIGO</p>
      </div>
      <div class="form-group">
        <label class="form-label">Nombre completo</label>
        <input type="text" class="form-input" id="crearNombre" placeholder="Lautaro López">
      </div>
      <div class="form-group">
        <label class="form-label">Email</label>
        <input type="email" class="form-input" id="crearEmail" placeholder="lautaro@gmail.com">
      </div>
      <div class="form-group">
        <label class="form-label">% de comisión (default 20)</label>
        <input type="number" class="form-input" id="crearComision" placeholder="20" min="1" max="50">
        <p class="form-hint">Porcentaje sobre el precio del plan al momento del pago. Se acumula en USDT.</p>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="cerrarModal('modalCrear')">Cancelar</button>
      <button class="btn btn-gold" id="btnCrear" onclick="crearAfiliado()">Crear afiliado</button>
    </div>
  </div>
</div>

<!-- Modal Resultado Creación -->
<div class="modal-overlay" id="modalCreado">
  <div class="modal">
    <div class="modal-header">
      <h3 class="modal-title">✓ Afiliado creado</h3>
      <button class="modal-close" onclick="cerrarModal('modalCreado')">✕</button>
    </div>
    <div class="modal-body" id="creadoBody">
      <!-- Se llena dinámicamente -->
    </div>
    <div class="modal-footer">
      <button class="btn btn-gold" onclick="cerrarModal('modalCreado');cargarPanel()">Listo</button>
    </div>
  </div>
</div>

<!-- Modal Detalle Afiliado -->
<div class="modal-overlay" id="modalDetalle">
  <div class="modal">
    <div class="modal-header">
      <h3 class="modal-title" id="detalleTitle">Detalle</h3>
      <button class="modal-close" onclick="cerrarModal('modalDetalle')">✕</button>
    </div>
    <div class="modal-body" id="detalleBody">
      <div class="loading-row"><span class="spinner-sm"></span>Cargando…</div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="cerrarModal('modalDetalle')">Cerrar</button>
      <button class="btn btn-green btn-sm" id="btnPagarTodo" onclick="pagarTodo()">Marcar todo como pagado</button>
    </div>
  </div>
</div>

<!-- Toast -->
<div class="toast" id="toast"></div>

<script>
const WORKER = 'https://legalai-worker.finmap-ia.workers.dev';
const FRONTEND = 'https://legalai-arg.com';
const PLANES = { starter:'Starter', standard:'Standard', pro:'PRO', business:'Business', enterprise:'Enterprise' };

let adminKey = '';
let refDetalle = '';

// ── Auth ──────────────────────────────────────────────────────────
function login() {
  const k = document.getElementById('authInput').value.trim();
  if (!k) return;
  adminKey = k;
  // Verificar con una llamada real al worker
  fetch(`${WORKER}/admin/afiliado/lista`, { headers: { 'x-admin-key': k } })
    .then(r => {
      if (r.status === 401) { document.getElementById('authError').style.display='block'; adminKey=''; return; }
      document.getElementById('authScreen').style.display = 'none';
      document.getElementById('panel').style.display = 'block';
      cargarPanel();
    })
    .catch(() => { document.getElementById('authError').style.display='block'; adminKey=''; });
}

// ── Cargar panel ──────────────────────────────────────────────────
async function cargarPanel() {
  document.getElementById('tablaAfiliados').innerHTML = '<div class="loading-row"><span class="spinner-sm"></span>Cargando…</div>';

  try {
    const res  = await fetch(`${WORKER}/admin/afiliado/lista`, { headers: { 'x-admin-key': adminKey } });
    const data = await res.json();
    if (!data.ok) { toast('Error cargando afiliados', 'err'); return; }

    const afiliados = data.afiliados || [];

    // Stats globales
    let activos = 0, convs = 0, pending = 0, pagado = 0;
    afiliados.forEach(a => {
      if (a.active) activos++;
      const e = a.earnings || {};
      pending += e.pending || 0;
      pagado  += e.paid    || 0;
      // No tenemos total de convs en lista, se verá en detalle
    });

    document.getElementById('sActivos').textContent  = activos;
    document.getElementById('sConvs').textContent    = '—';
    document.getElementById('sPending').textContent  = '$' + pending.toFixed(2);
    document.getElementById('sPaid').textContent     = '$' + pagado.toFixed(2);

    if (!afiliados.length) {
      document.getElementById('tablaAfiliados').innerHTML = '<div class="loading-row">No hay afiliados aún. Creá el primero.</div>';
      return;
    }

    document.getElementById('tablaAfiliados').innerHTML = afiliados.map(a => {
      const e = a.earnings || {};
      return `
      <div class="t-row aff-cols" onclick="verDetalle('${a.ref}')">
        <div>
          <p class="cell-name">${esc(a.nombre)}</p>
          <p class="cell-sub">${esc(a.email)}</p>
        </div>
        <span class="cell-ref">${a.ref}</span>
        <span class="cell-pct">${a.commission_pct}%</span>
        <span class="cell-money money-pending">$${(e.pending||0).toFixed(2)}</span>
        <span class="cell-money money-paid">$${(e.paid||0).toFixed(2)}</span>
        <span class="pill ${a.active?'active':'inactive'}"><span class="pill-dot"></span>${a.active?'Activo':'Inactivo'}</span>
        <div class="cell-actions" onclick="event.stopPropagation()">
          <button class="btn btn-outline btn-sm" onclick="verDetalle('${a.ref}')">Ver</button>
          <button class="btn btn-green btn-sm" onclick="pagarAfiliado('${a.ref}')">Pagar</button>
          <button class="btn btn-outline btn-sm" title="Copiar link" onclick="copiar('${FRONTEND}/planes.html?ref=${a.ref}')">Link</button>
        </div>
      </div>`;
    }).join('');

  } catch(e) {
    toast('Error de conexión', 'err');
  }
}

// ── Ver detalle ───────────────────────────────────────────────────
async function verDetalle(ref) {
  refDetalle = ref;
  document.getElementById('detalleTitle').textContent = `Detalle · ${ref}`;
  document.getElementById('detalleBody').innerHTML    = '<div class="loading-row"><span class="spinner-sm"></span>Cargando…</div>';
  document.getElementById('modalDetalle').classList.add('open');

  try {
    const res  = await fetch(`${WORKER}/admin/afiliado/detalle?ref=${ref}&admin_key=${encodeURIComponent(adminKey)}`);
    const data = await res.json();
    if (!data.ok) { document.getElementById('detalleBody').innerHTML = `<p style="color:var(--red)">${data.error}</p>`; return; }

    const a = data.afiliado, e = data.earnings;
    const convs = data.conversiones || [];
    const pendConvs = convs.filter(c=>!c.paid);

    document.getElementById('btnPagarTodo').style.display = pendConvs.length ? 'inline-flex' : 'none';

    let html = `
      <div class="info-row"><span class="info-key">Nombre</span><span class="info-val">${esc(a.nombre)}</span></div>
      <div class="info-row"><span class="info-key">Email</span><span class="info-val">${esc(a.email)}</span></div>
      <div class="info-row"><span class="info-key">Comisión</span><span class="info-val">${a.commission_pct}%</span></div>
      <div class="info-row"><span class="info-key">Total ganado</span><span class="info-val gold">$${(e.total||0).toFixed(2)} USDT</span></div>
      <div class="info-row"><span class="info-key">Pendiente</span><span class="info-val gold">$${(e.pending||0).toFixed(2)} USDT</span></div>
      <div class="info-row"><span class="info-key">Cobrado</span><span class="info-val green">$${(e.paid||0).toFixed(2)} USDT</span></div>
      <div class="info-row"><span class="info-key">Dashboard afiliado</span><span class="info-val" style="font-size:11px"></span></div>
    `;

    html += `<div class="url-box" onclick="copiar('${esc(data.dashboard_url)}')" title="Click para copiar">${esc(data.dashboard_url)}</div>`;

    if (convs.length) {
      html += `<p style="font-size:12px;color:var(--muted);margin-top:20px;margin-bottom:4px;">CONVERSIONES (${convs.length})</p>`;
      html += `<div class="conv-mini">
        <div class="conv-mini-head">
          <span class="th">Plan</span><span class="th">Fecha</span>
          <span class="th">Monto</span><span class="th">Comisión</span><span class="th">Estado</span>
        </div>`;
      html += convs.map(c=>`
        <div class="conv-mini-row">
          <span style="color:var(--text);font-weight:600">${PLANES[c.plan_id]||c.plan_id}</span>
          <span style="color:var(--muted);font-family:'DM Mono',monospace">${fmt(c.created_at)}</span>
          <span style="color:var(--muted);font-family:'DM Mono',monospace">$${(c.amount||0).toFixed(2)}</span>
          <span style="color:var(--gold);font-family:'DM Mono',monospace">$${(c.commission||0).toFixed(2)}</span>
          <span class="pill ${c.paid?'active':'pending'}" style="${c.paid?'':'background:#1a140a;color:var(--gold);border:1px solid #3a2e10'}">
            <span class="pill-dot"></span>${c.paid?'Pagado':'Pendiente'}
          </span>
        </div>`).join('');
      html += `</div>`;
    } else {
      html += `<p style="font-size:13px;color:var(--faint);margin-top:20px;text-align:center;">Sin conversiones todavía.</p>`;
    }

    document.getElementById('detalleBody').innerHTML = html;
  } catch(e) {
    document.getElementById('detalleBody').innerHTML = '<p style="color:var(--red)">Error de conexión</p>';
  }
}

// ── Pagar ─────────────────────────────────────────────────────────
async function pagarAfiliado(ref) {
  if (!confirm(`¿Marcar todas las comisiones pendientes de ${ref} como pagadas?`)) return;
  await pagar(ref);
}

async function pagarTodo() {
  if (!refDetalle) return;
  if (!confirm(`¿Marcar todas las comisiones pendientes de ${refDetalle} como pagadas?`)) return;
  await pagar(refDetalle);
  await verDetalle(refDetalle);
}

async function pagar(ref) {
  try {
    const res = await fetch(`${WORKER}/admin/afiliado/pagar`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-admin-key': adminKey },
      body: JSON.stringify({ ref, all_pending: true })
    });
    const data = await res.json();
    if (!data.ok) { toast(data.error||'Error', 'err'); return; }
    toast(`Marcadas ${data.procesadas} comisiones como pagadas. Total: $${data.comision_pagada} USDT`, 'ok');
    cargarPanel();
  } catch(e) {
    toast('Error de conexión', 'err');
  }
}

// ── Crear afiliado ────────────────────────────────────────────────
function abrirModalCrear() {
  document.getElementById('crearRef').value = '';
  document.getElementById('crearNombre').value = '';
  document.getElementById('crearEmail').value = '';
  document.getElementById('crearComision').value = '';
  document.getElementById('modalCrear').classList.add('open');
}

async function crearAfiliado() {
  const ref    = document.getElementById('crearRef').value.trim().toUpperCase();
  const nombre = document.getElementById('crearNombre').value.trim();
  const email  = document.getElementById('crearEmail').value.trim();
  const comision = parseInt(document.getElementById('crearComision').value)||20;

  if (!ref||!nombre||!email) { toast('Completá todos los campos', 'err'); return; }
  if (!email.includes('@'))  { toast('Email inválido', 'err'); return; }

  const btn = document.getElementById('btnCrear');
  btn.disabled = true; btn.textContent = 'Creando…';

  try {
    const res = await fetch(`${WORKER}/admin/afiliado/crear`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-admin-key': adminKey },
      body: JSON.stringify({ ref, nombre, email, commission_pct: comision })
    });
    const data = await res.json();
    btn.disabled = false; btn.textContent = 'Crear afiliado';

    if (!data.ok) { toast(data.error||'Error al crear', 'err'); return; }

    cerrarModal('modalCrear');
    document.getElementById('creadoBody').innerHTML = `
      <div class="info-row"><span class="info-key">Nombre</span><span class="info-val">${esc(nombre)}</span></div>
      <div class="info-row"><span class="info-key">Código</span><span class="info-val mono">${data.ref}</span></div>
      <div class="info-row"><span class="info-key">Comisión</span><span class="info-val">${comision}%</span></div>
      <p style="font-size:12px;color:var(--muted);margin-top:20px;margin-bottom:6px;">LINK PARA COMPARTIR</p>
      <div class="url-box" onclick="copiar('${esc(data.link_afiliado)}')" title="Click para copiar">${esc(data.link_afiliado)}</div>
      <p style="font-size:12px;color:var(--muted);margin-top:16px;margin-bottom:6px;">DASHBOARD DEL AFILIADO (mandárselo a él/ella)</p>
      <div class="url-box" onclick="copiar('${esc(data.dashboard_url)}')" title="Click para copiar">${esc(data.dashboard_url)}</div>
      <p style="font-size:11px;color:var(--faint);margin-top:10px;">Guardá estas URLs. El dashboard ya está activo con la key incluida.</p>
    `;
    document.getElementById('modalCreado').classList.add('open');
    cargarPanel();
  } catch(e) {
    btn.disabled = false; btn.textContent = 'Crear afiliado';
    toast('Error de conexión', 'err');
  }
}

// ── Utils ─────────────────────────────────────────────────────────
function cerrarModal(id) { document.getElementById(id).classList.remove('open'); }

function copiar(txt) {
  navigator.clipboard.writeText(txt).then(()=>toast('Copiado al portapapeles', 'ok'));
}

function toast(msg, tipo='ok') {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.className = 'toast show ' + tipo;
  setTimeout(()=>{ el.className='toast'; }, 3500);
}

function fmt(ts) {
  return new Date(ts).toLocaleDateString('es-AR',{day:'2-digit',month:'2-digit',year:'2-digit'});
}

function esc(s) {
  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// Cerrar modales con Escape
document.addEventListener('keydown', e => {
  if (e.key==='Escape') {
    ['modalCrear','modalCreado','modalDetalle'].forEach(id=>cerrarModal(id));
  }
});
document.addEventListener('keydown', e => {
  if (e.key==='Enter' && document.getElementById('authScreen').style.display!=='none') login();
});
</script>
